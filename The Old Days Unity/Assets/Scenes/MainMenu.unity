  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroDialogueManager
  blackScreenPanel: {fileID: 579766669}
  speakerNameText: {fileID: 1913667211}
  dialogueText: {fileID: 1644928624}
  continueHintText: {fileID: 1822566305}
  charactersPerSecond: 9
  commaPauseTime: 0.2
  punctuationPauseTime: 0.25
  dialogueLines:
  - speakerName: Daughter
    textLine: Mom... we're going to be away for the whole week.
  - speakerName: Margaret
    textLine: Alright.
  - speakerName: Daughter
    textLine: I asked Anna to stop by and check on you..
  - speakerName: Margaret
    textLine: You didn't have to.
  - speakerName: Daughter
    textLine: I just wanted to make sure you're okay.
  - speakerName: Margaret
    textLine: I've been looking after myself longer than you've been alive.
  - speakerName: Daughter
    textLine: Mom... you're ninety.
  - speakerName: Margaret
    textLine: And?
  - speakerName: Daughter
    textLine: I'll call you every day.
  - speakerName: Margaret
    textLine: Don't make a habit of it.
  - speakerName: Daughter
    textLine: ...Fine. Just answer the phone, okay?
  - speakerName: Daughter
    textLine: We'll be back next week
  - speakerName: Margaret
    textLine: Then stop standing around and go enjoy your trip.
  - speakerName: Daughter
    textLine: See you next week Mom!
  - speakerName: 
    textLine: ...
  - speakerName: Margaret
    textLine: ...Do they really think I'm that helpless?
  blackScreenWaitTime: 2
  introMusicClip: {fileID: 8300000, guid: e01560b934b605949887c55f5da9fd34, type: 3}
  introMusicVolume: 0.5
  introMusicFadeIn: 1.5
  introMusicFadeOut: 1.5
